#!/usr/bin/env nix-shell
#! nix-shell -p pandoc -i bash
# SPDX-License-Identifier: 0BSD

set -eu

cd "$(dirname "$0")"
OUTDIR="_html"
mkdir -p "$OUTDIR"

# 收集所有 md 文件，按 overview → 字母序排列
FILES=""
for f in on-disk-format/overview.md on-disk-format/*.md; do
    [ -f "$f" ] && FILES="$FILES $f"
done

# 生成合并 HTML
echo "生成合并文档..."
pandoc -s --toc \
    --metadata title="Btrfs 磁盘格式文档" \
    --lua-filter=link-html.lua \
    -o "$OUTDIR/all.html" \
    $FILES

echo "生成单页..."
for f in on-disk-format/*.md; do
    name="$(basename "$f" .md)"
    pandoc -s \
        --metadata title="Btrfs 磁盘格式 — $name" \
        --lua-filter=link-html.lua \
        -o "$OUTDIR/$name.html" \
        "$f"
done

# 生成索引页
{
    echo '<!DOCTYPE html><html lang="zh"><head><meta charset="utf-8"><title>Btrfs 磁盘格式文档</title></head><body>'
    echo '<h1>Btrfs 磁盘格式文档</h1><ul>'
    for f in on-disk-format/*.md; do
        name="$(basename "$f" .md)"
        echo "<li><a href=\"$name.html\">$name</a></li>"
    done
    echo '</ul><hr><p><a href="all.html">合并全文（含目录）</a></p></body></html>'
} > "$OUTDIR/index.html"

if [ "${1:-}" = "--open" ]; then
    xdg-open "$OUTDIR/index.html"
fi
echo "已生成 HTML 到 $OUTDIR/"
